# ============================================================
# bythanh-chatbot-test — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# Google AI Studio — free tier; Promptfoo `llm-rubric` uses `google:gemini-2.0-flash` (see promptfooconfig.yaml)
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: OpenAI if you switch YAML back to openai:gpt-4o-mini
# OPENAI_API_KEY=

# Optional: Playwright baseURL / promptfoo site (first match wins: BASE_URL → PLAYWRIGHT_BASE_URL → CHATBOT_API_BASE_URL → default)
# BASE_URL=https://bythanh.com
# PLAYWRIGHT_BASE_URL=https://bythanh.com

# Chatbot API config (used by tests/content/content.spec.ts)
CHATBOT_API_BASE_URL=https://bythanh.com
CHATBOT_THREAD_ID=your_thread_id_here
CHATBOT_API_TIMEOUT_MS=60000
CHATBOT_API_COOKIE=
CHATBOT_API_USER_AGENT=

# API test suite (tests/api/api-chatbot.spec.ts)
# Per-case latency is defined in data/datasets.ts; this is suite-level guard for manual runs.
AI_API_MAX_LATENCY_MS=2000
