# ============================================================
# bythanh-chatbot-test — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# Google Gemini API Key — used as LLM judge in Promptfoo eval
# Free tier: 60 requests/min, no credit card needed
# Get key at: https://aistudio.google.com/apikey
OPENAI_API_KEY=your_open_api_key_here

# Chatbot API config (used by tests/content.spec.ts)
CHATBOT_API_BASE_URL=https://bythanh.com
CHATBOT_THREAD_ID=your_thread_id_here
CHATBOT_API_TIMEOUT_MS=60000
CHATBOT_API_COOKIE=
CHATBOT_API_USER_AGENT=

# API test suite (tests/api/api-chatbot.spec.ts)
# Per-case latency is defined in data/apiTestDataset.ts; this is suite-level guard for manual runs.
AI_API_MAX_LATENCY_MS=2000
