{
  "name": "bythanh-chatbot-test",
  "version": "1.0.0",
  "description": "Playwright + Promptfoo automation test suite for bythanh.com chatbot",
  "scripts": {
    "test": "playwright test --workers=1",
    "test:ui": "playwright test tests/ui.spec.ts --workers=1",
    "test:content": "playwright test tests/content.spec.ts --workers=1",
    "test:headed": "playwright test --headed --workers=1",
    "test:report": "playwright show-report",
    "eval": "promptfoo eval --config promptfooconfig.yaml",
    "eval:view": "promptfoo view"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "promptfoo": "^0.121.4",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
