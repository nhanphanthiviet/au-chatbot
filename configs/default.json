{
    "envTest": "prod",
    "browser": "chrome",
    "headlessMode": true,
    "timeout": 30000,
    "botTimeout": 120000,
    "skipPendingTests": true,
    "skipTests": true,
    "notStaging": true,
    "parallelism": {
